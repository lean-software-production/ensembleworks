{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "paths": {
      "@ensembleworks/contracts": ["../contracts/src/index.ts"],
      "@ensembleworks/canvas-model": ["../canvas-model/src/index.ts"],
      "@ensembleworks/canvas-editor": ["../canvas-editor/src/index.ts"],
      "@ensembleworks/canvas-react": ["../canvas-react/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
