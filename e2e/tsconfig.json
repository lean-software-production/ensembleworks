{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "bun-types"]
  },
  "include": ["playwright.config.ts", "lib/**/*.ts", "tests/**/*.ts", "perf/**/*.ts", "scripts/**/*.ts"]
}
