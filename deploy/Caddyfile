# EnsembleWorks — DEV/watch Caddy edge config (Vite-fronted). Used by:
#   - devcontainer: workspace-up.bash runs `caddy run` against this directly;
#     GitHub Codespaces forwards port 8080 over HTTPS.
#   - ash dogfood box: bootstrap-debian-ash.sh copies this to /etc/caddy/Caddyfile;
#     a Cloudflare Tunnel forwards the public hostname to http://localhost:8080,
#     with a Cloudflare Access policy in front.
# Production client boxes use deploy/Caddyfile.prod instead (static client served
# by the sync server; no Vite), installed by deploy/deploy.sh.
#
# Caddy serves plain HTTP on :8080 — TLS is always terminated upstream. Vite
# (the client dev server) serves the app and proxies the backend services
# (/sync, /api, /uploads, /term), so Caddy's ONLY job is the same-origin
# /dev/{port} proxy that Vite can't express. Everything else goes to Vite.

:8080 {
	# LiveKit OSS signaling WS -> livekit-server on localhost:7880. Media (UDP
	# 50000-50300) flows direct browser<->SFU and does NOT go through Caddy.
	# CF Access covers the whole canvas.leansoftware.ai domain, so /livekit
	# inherits browser-cookie auth; the LiveKit JWT is a second layer.
	@livekit path /livekit /livekit/*
	handle @livekit {
		# LiveKit's signaling WS endpoint is at the SFU root (localhost:7880/),
		# not /livekit — strip the prefix before proxying or the SFU returns 404
		# and browser media never connects.
		uri strip_prefix /livekit
		reverse_proxy localhost:7880
	}

	# Embedded dev servers, proxied under the canvas origin so the iframes are
	# same-protocol and reachable by every participant: /dev/3000/... -> :3000.
	@dev path_regexp dev ^/dev/(\d+)(/.*)?$
	handle @dev {
		uri strip_prefix /dev/{re.dev.1}
		reverse_proxy localhost:{re.dev.1}
	}

	# Everything else (app + HMR, and Vite's own proxying of /sync, /api,
	# /uploads, /term to the sync server and terminal gateway) -> Vite.
	handle {
		reverse_proxy localhost:5173
	}
}
