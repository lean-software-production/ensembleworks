# EnsembleWorks — DEV/watch Caddy edge config (Vite-fronted). Used by:
#   - devcontainer/native dev stack: bin/dev (caddy window) runs `caddy run` against this;
#     GitHub Codespaces forwards port 8080 over HTTPS.
#   - ash dogfood box: bootstrap-debian-ash.sh copies this to /etc/caddy/Caddyfile;
#     a Cloudflare Tunnel forwards the public hostname to http://localhost:8080,
#     with a Cloudflare Access policy in front.
# Production client boxes use deploy/Caddyfile.prod instead (static client served
# by the sync server; no Vite), installed by deploy/deploy.sh.
#
# Caddy serves plain HTTP on :8080 by default — TLS is normally terminated
# upstream (Codespaces, a Cloudflare Tunnel, tailscale serve). Vite (the client
# dev server) serves the app + HMR; the backend services (/sync WS, /api,
# /uploads, /api/terminal) are routed by Caddy DIRECTLY to the sync server and
# terminal gateway, NOT through Vite — Vite's server.proxy can't forward an
# upstream WebSocket under Bun's runtime, so /sync would hang if funnelled
# through it. This mirrors the prod split (deploy/Caddyfile.prod).
#
# Direct LAN access has no upstream TLS terminator, but browsers gate
# crypto.randomUUID and getUserMedia (the mic — so voice) behind a secure
# context, which a LAN IP over plain http is NOT. So bin/dev can make Caddy
# terminate TLS itself with its internal (self-signed) CA: it sets
# ENSEMBLEWORKS_CADDY_SITE=https://<host>:8080 and CADDY_TLS_DIRECTIVE="tls
# internal". Both default to the plain-:8080 shape, so upstream-TLS and native
# users are unaffected.
#
# The five upstream targets below are also env-parameterized, for the same
# ENSEMBLEWORKS_PORT_OFFSET multi-stack-per-host dev feature (bin/dev sets
# these alongside ENSEMBLEWORKS_CADDY_SITE); their defaults are today's
# production ports, so an unset environment (e.g. the ash dogfood box, which
# copies this file with no env set) reproduces this file's pre-offset shape.

# auto_https disable_redirects: serve TLS on the site's port but don't try to
# bind :80 for an http->https redirect (fails as non-root, and unwanted here).
# ENSEMBLEWORKS_CADDY_GLOBAL carries `default_sni <host>` in TLS mode: a browser
# hitting a bare IP sends no SNI, so Caddy needs a default to pick the cert.
# Empty (a blank line) by default.
{
	auto_https disable_redirects
	{$ENSEMBLEWORKS_CADDY_GLOBAL:}
}

{$ENSEMBLEWORKS_CADDY_SITE::8080} {
	{$ENSEMBLEWORKS_CADDY_TLS_DIRECTIVE:}
	# LiveKit OSS signaling WS -> livekit-server on localhost:7880. Media (UDP
	# 50000-50300) flows direct browser<->SFU and does NOT go through Caddy.
	# CF Access covers the whole canvas.leansoftware.ai domain, so /livekit
	# inherits browser-cookie auth; the LiveKit JWT is a second layer.
	@livekit path /livekit /livekit/*
	handle @livekit {
		# LiveKit's signaling WS endpoint is at the SFU root (localhost:7880/),
		# not /livekit — strip the prefix before proxying or the SFU returns 404
		# and browser media never connects.
		uri strip_prefix /livekit
		reverse_proxy localhost:{$ENSEMBLEWORKS_PORT_LIVEKIT:7880}
	}

	# Embedded dev servers, proxied under the canvas origin so the iframes are
	# same-protocol and reachable by every participant: /dev/3000/... -> :3000.
	@dev path_regexp dev ^/dev/(\d+)(/.*)?$
	handle @dev {
		uri strip_prefix /dev/{re.dev.1}
		reverse_proxy localhost:{re.dev.1}
	}

	# The shared browser (neko container, ensembleworks-shared-browser.service) is
	# a permanent service, so it gets its OWN named route rather than riding
	# /dev/{port}. neko's HTTP+WS is on loopback :8090; it serves at root with
	# relative asset/WS paths, so stripping the prefix is all it needs (verified —
	# same mechanism as /dev). reverse_proxy upgrades the control WebSocket; the
	# WebRTC media is UDP and does NOT pass through here. The neko shape's `base`
	# points at /shared-browser/ (client/src/neko/NekoShapeUtil.tsx).
	@shared-browser path /shared-browser /shared-browser/*
	handle @shared-browser {
		uri strip_prefix /shared-browser
		reverse_proxy localhost:{$ENSEMBLEWORKS_PORT_NEKO:8090}
	}

	# Terminal LOCAL plane (node-pty + tmux; WebSocket) -> the gateway process on
	# :8789. The RELAY plane (/api/terminal/{status,list,connect,relay}) stays on
	# the sync server via @backend below. Mirrors deploy/Caddyfile.prod.
	@term_local path /api/terminal/health /api/terminal/sessions /api/terminal/sessions/* /api/terminal/ws
	handle @term_local {
		reverse_proxy 127.0.0.1:{$ENSEMBLEWORKS_PORT_TERM:8789}
	}

	# Backend traffic -> the sync server on :8788 DIRECTLY (not via Vite). Vite's
	# server.proxy cannot forward an upstream WebSocket under Bun's runtime (its
	# built-in HMR ws works, but proxied upstream ws upgrades never complete), so
	# the /sync tldraw socket must reach the sync server through Caddy. /api,
	# /uploads and /files ride the same route for symmetry with prod. Caddy
	# upgrades the WS natively. (vite.config.ts still lists these under
	# server.proxy for the rare case of hitting Vite on :5173 directly; behind
	# Caddy this route wins first.)
	@backend path /sync /sync/* /api /api/* /uploads /uploads/* /files /files/*
	handle @backend {
		reverse_proxy 127.0.0.1:{$ENSEMBLEWORKS_PORT_SYNC:8788}
	}

	# Everything else — the app shell, HMR (/@vite/client WS), and client assets
	# -> Vite. 127.0.0.1, not localhost: vite.config.ts pins Vite to the IPv4
	# loopback (Bun ignores the container's --dns-result-order=ipv4first, so
	# `localhost` would otherwise resolve to IPv6 ::1). Caddy resolves `localhost`
	# to ::1 first, so a `localhost` upstream here would 502 on connection-refused.
	handle {
		reverse_proxy 127.0.0.1:{$ENSEMBLEWORKS_PORT_CLIENT:5173}
	}
}
