# EnsembleWorks shared-browser (neko) service config.
# Copy to ~/.config/ensembleworks/shared-browser.env (mode 600, owned by the
# service user) and fill in. Consumed by ensembleworks-shared-browser.service and
# by the dev launcher (~/Work/ensembleworks-devserver). Keep it OUT of git.

# Pinned image — use a digest (not :latest) so dev and prod run the same neko.
NEKO_IMAGE=ghcr.io/m1k1o/neko/firefox@sha256:REPLACE_WITH_PINNED_DIGEST

# Virtual screen size + framerate. Drives encode CPU; the shape locks to 16:9.
# Lower the framerate (e.g. @20) on weak CPUs — browsing doesn't need 30fps and
# it's a near-linear CPU saving.
NEKO_SCREEN=1280x720@30

# WebRTC video codec: vp8 (default, universal) | vp9 | h264 | av1. On weak/older
# CPUs (e.g. OVH "Haswell"-class) prefer h264 — x264 encodes ~2x cheaper than VP8
# at comparable quality, and it's a mandatory WebRTC codec so all browsers handle it.
# MUST be set (the systemd unit passes it through with no default).
NEKO_VIDEO_CODEC=vp8

# Member passwords (multiuser provider).
#  - USER rides in the per-viewer shape URL. It MUST stay `neko`: the client hardcodes
#    `pwd=neko` (client/src/neko/NekoShapeUtil.tsx — NEKO_USER_PASSWORD / buildNekoSrc),
#    so any other value makes the browser shape fail with "unauthorized". It is not a
#    real secret (the origin is gated by CF Access in prod / the tailnet on the dev box).
#    Leave it as-is until the client makes the user password configurable.
#  - ADMIN is a real secret used for kick/screen-resize etc. — it NEVER goes in a
#    URL. Change it from the default.
NEKO_USER_PASSWORD=neko
NEKO_ADMIN_PASSWORD=CHANGE_ME

# WebRTC media: one UDP mux port + the advertised (NAT1to1) IP. Pick a port
# OUTSIDE the LiveKit media range (50000-50300).
NEKO_UDPMUX=52000

# NAT1to1 = the IP browsers reach this box on, pinned (no STUN). Per environment:
#   dev box (baljeet, tailnet):  the tailnet IP — `tailscale ip -4` (e.g. 100.127.227.76)
#                                no firewall rule needed (tailnet ACLs govern).
#   prod (Hetzner):              the public IPv4 (e.g. 178.156.162.162), AND open
#                                NEKO_UDPMUX/udp in ufw + the Hetzner cloud
#                                firewall (rule name "shared-browser-media-UDP"),
#                                exactly like the LiveKit media range.
NEKO_NAT1TO1=CHANGE_ME
