{
  "name": "@ensembleworks/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/sync-server.ts",
    "dev:term": "bun --watch src/terminal-gateway.ts",
    "dev:files": "bun --watch src/file-server.ts",
    "start": "bun src/sync-server.ts",
    "start:term": "bun src/terminal-gateway.ts",
    "start:files": "bun src/file-server.ts",
    "build:binary": "bun build --compile --sourcemap --target=${EW_TARGET:-bun-linux-x64} src/main.ts --outfile dist/ensembleworks-server",
    "build": "bunx tsc --noEmit",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@ensembleworks/canvas-doc": "*",
    "@ensembleworks/canvas-model": "*",
    "@ensembleworks/canvas-sync": "*",
    "@ensembleworks/contracts": "*",
    "@tldraw/sync-core": "5.1.0",
    "@tldraw/tlschema": "5.1.0",
    "@tldraw/utils": "5.1.0",
    "@tldraw/validate": "5.1.0",
    "express": "^5.0.0",
    "livekit-server-sdk": "2.15.4",
    "marked": "^18.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "bun-types": "1.3.14",
    "typescript": "^5.7.0"
  }
}
